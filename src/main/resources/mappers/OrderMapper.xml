<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.deushu.order.mapper.OrderMapper">

    <select id="findItemByIdWithPessimisticLock" resultType="com.deushu.order.domain.ItemEntity">
        SELECT *
        FROM items
        WHERE id = #{id}
        FOR UPDATE
    </select>

    <update id="updateItemStock" parameterType="com.deushu.order.domain.ItemEntity">
        UPDATE items
        SET stock = #{stock},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <insert id="insertOrder" parameterType="com.deushu.order.domain.OrderEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO orders (member_id, store_id, order_status, total_price, pickup_code, created_at, updated_at)
        VALUES (#{memberId}, #{storeId}, #{orderStatus}, #{totalPrice}, #{pickupCode}, NOW(), NOW())
    </insert>

    <insert id="insertOrderItems">
        INSERT INTO order_items (order_id, item_id, quantity, order_price, created_at)
        VALUES
        <foreach collection="orderItems" item="item" separator=",">
            (#{item.orderId}, #{item.itemId}, #{item.quantity}, #{item.orderPrice}, NOW())
        </foreach>
    </insert>

	<select id="findOrderById" resultType="com.deushu.order.domain.OrderEntity">
        SELECT *
        FROM orders
        WHERE id = #{id}
    </select>

    <update id="updateOrderStatus" parameterType="com.deushu.order.domain.OrderEntity">
        UPDATE orders
        SET order_status = #{orderStatus},
            updated_at = NOW()
        WHERE id = #{id}
    </update>
    
     <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
         вҳ… мӢ к·ң м¶”к°Җ 1: pickupCodeлЎң мЈјл¬ё лӢЁкұҙ мЎ°нҡҢ
         OrderQrService.verifyPickup() / completePickup() м—җм„ң мӮ¬мҡ©
    в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
    <select id="findOrderByPickupCode"
            parameterType="string"
            resultType="com.deushu.order.domain.OrderEntity">
        SELECT
            id,
            member_id   AS memberId,
            store_id    AS storeId,
            order_status AS orderStatus,
            total_price  AS totalPrice,
            pickup_code  AS pickupCode,
            created_at   AS createdAt,
            updated_at   AS updatedAt
        FROM orders
        WHERE pickup_code = #{pickupCode}
        LIMIT 1
    </select>

    <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
         вҳ… мӢ к·ң м¶”к°Җ 2: мЈјл¬ё мғҒн’Ҳ мў…лҘҳ мҲҳ мЎ°нҡҢ
         OrderQrService.verifyPickup() м—җм„ң мӮ¬мҡ©
    в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
    <select id="countOrderItems"
            parameterType="long"
            resultType="int">
        SELECT COUNT(*)
        FROM order_items
        WHERE order_id = #{orderId}
    </select>

    <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
         вҳ… мӢ к·ң м¶”к°Җ 3: pickupCode кё°л°ҳ мЈјл¬ё мғҒнғң ліҖкІҪ
         OrderQrService.completePickup() м—җм„ң мӮ¬мҡ©
         PAYMENT_COMPLETED вҶ’ PICKUP_COMPLETED
    в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
    <update id="updateStatusByPickupCode">
        UPDATE orders
        SET
            order_status = #{status},
            updated_at   = NOW()
        WHERE pickup_code = #{pickupCode}
    </update>

</mapper>