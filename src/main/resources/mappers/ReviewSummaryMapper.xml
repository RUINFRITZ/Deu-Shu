<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.deushu.store.mapper.ReviewSummaryMapper">

    <!--
        AI 요약용: 특정 가게의 전체 리뷰 조회
        - 삭제된 리뷰 제외 (deleted_at IS NULL)
        - 최신순 정렬
        - title, content, rating 만 가져와서 토큰 사용 최소화
    -->
    <select id="findAllReviewsByStoreId"
            parameterType="long"
            resultType="com.deushu.store.dto.ReviewForSummaryDto">
        SELECT
            r.title,
            r.content,
            r.rating
        FROM reviews r
        WHERE r.store_id = #{storeId}
          AND r.deleted_at IS NULL
        ORDER BY r.created_at DESC
    </select>

</mapper>